-- Create the schema if it does not exist
CREATE SCHEMA IF NOT EXISTS creds;

------------------------------------------------------------
-- 1. SEQUENCES
------------------------------------------------------------
CREATE SEQUENCE creds.seq_accessor START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE creds.seq_accessor_authority START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE creds.seq_accessor_authority_role START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE creds.seq_accessor_authority_role_permission START WITH 1 INCREMENT BY 1;

------------------------------------------------------------
-- 2. TABLES
------------------------------------------------------------

-- Main User Entity Table
CREATE TABLE creds.accessor (
    id BIGINT PRIMARY KEY DEFAULT nextval('creds.seq_accessor'),
    username VARCHAR(255) UNIQUE NOT NULL, -- Kept unique for authentication purposes
    password VARCHAR(255),
    access_expired BOOLEAN NOT NULL DEFAULT FALSE,
    access_locked BOOLEAN NOT NULL DEFAULT FALSE,
    access_enabled BOOLEAN NOT NULL DEFAULT TRUE,
    credentials_expired BOOLEAN NOT NULL DEFAULT FALSE,
    first_name VARCHAR(255),
    middle_name VARCHAR(255),
    last_name VARCHAR(255)
);

-- Authorities Table (Linked via accessor_id)
CREATE TABLE creds.accessor_authority (
    id BIGINT PRIMARY KEY DEFAULT nextval('creds.seq_accessor_authority'),
    accessor_id BIGINT NOT NULL REFERENCES creds.accessor(id) ON DELETE CASCADE,
    name VARCHAR(255) NOT NULL
);

-- Roles Table (Linked via authority_id)
CREATE TABLE creds.accessor_authority_role (
    id BIGINT PRIMARY KEY DEFAULT nextval('creds.seq_accessor_authority_role'),
    authority_id BIGINT NOT NULL REFERENCES creds.accessor_authority(id) ON DELETE CASCADE,
    name VARCHAR(255) NOT NULL
);

-- Permissions Table (Linked via role_id)
CREATE TABLE creds.accessor_authority_role_permission (
    id BIGINT PRIMARY KEY DEFAULT nextval('creds.seq_accessor_authority_role_permission'),
    role_id BIGINT NOT NULL REFERENCES creds.accessor_authority_role(id) ON DELETE CASCADE,
    role_name VARCHAR(255),
    class_path VARCHAR(255) NOT NULL,
    field_name VARCHAR(255),
    read BOOLEAN NOT NULL DEFAULT FALSE,
    "create" BOOLEAN NOT NULL DEFAULT FALSE, -- Escaped reserved keyword
    "update" BOOLEAN NOT NULL DEFAULT FALSE, -- Escaped reserved keyword
    "delete" BOOLEAN NOT NULL DEFAULT FALSE  -- Escaped reserved keyword
);



