-- Create the schema if it does not exist
CREATE SCHEMA IF NOT EXISTS auth;

------------------------------------------------------------
-- 1. SEQUENCES
------------------------------------------------------------
CREATE SEQUENCE auth.seq_access_id START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE auth.seq_authority_id START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE auth.seq_role_id START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE auth.seq_permission_id START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE auth.seq_access_authority_id START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE auth.seq_authority_role_id START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE auth.seq_role_permission_id START WITH 1 INCREMENT BY 1;


------------------------------------------------------------
-- 2. TABLES
------------------------------------------------------------

-- Main User Entity Table
CREATE TABLE auth.access (
    id BIGINT PRIMARY KEY DEFAULT nextval('auth.seq_access_id'),
    username VARCHAR(255) UNIQUE NOT NULL, -- Kept unique for authentication purposes
    password VARCHAR(255),
    first_name VARCHAR(255),
    middle_name VARCHAR(255),
    last_name VARCHAR(255),
    access_expired BOOLEAN NOT NULL DEFAULT FALSE,
    access_locked BOOLEAN NOT NULL DEFAULT FALSE,
    access_enabled BOOLEAN NOT NULL DEFAULT TRUE,
    credentials_expired BOOLEAN NOT NULL DEFAULT FALSE
);

-- Authorities Table (Linked via access_id)
CREATE TABLE auth.authority (
    id BIGINT PRIMARY KEY DEFAULT nextval('auth.seq_authority_id'),
    name VARCHAR(255) UNIQUE NOT NULL,
    description VARCHAR(255) NOT NULL
);

CREATE TABLE auth.access_authority_id (
    id BIGINT PRIMARY KEY DEFAULT nextval('auth.seq_access_authority_id'),
    access_id BIGINT NOT NULL,
    authority_id BIGINT NOT NULL,
	CONSTRAINT uq_access_authority_comb UNIQUE (access_id, authority_id)
);

-- Roles Table (Linked via authority_id)
CREATE TABLE auth.role (
    id BIGINT PRIMARY KEY DEFAULT nextval('auth.seq_role_id'),
    name VARCHAR(255) UNIQUE NOT NULL,
    description VARCHAR(255) NOT NULL
);

CREATE TABLE auth.authority_role_id (
    id BIGINT PRIMARY KEY DEFAULT nextval('auth.seq_authority_role_id'),
    authority_id BIGINT NOT NULL,
    role_id BIGINT NOT NULL,
	CONSTRAINT uq_authority_role_id UNIQUE (authority_id, role_id)
);

-- Permissions Table (Linked via role_id)
CREATE TABLE auth.permission (
    id BIGINT PRIMARY KEY DEFAULT nextval('auth.seq_permission_id'),
    app_id VARCHAR(255) NOT NULL
    fully_qualified_field_name VARCHAR(255) NOT NULL,
    read_ BOOLEAN NOT NULL DEFAULT FALSE,
    create_ BOOLEAN NOT NULL DEFAULT FALSE,
    update_ BOOLEAN NOT NULL DEFAULT FALSE,
    delete_ BOOLEAN NOT NULL DEFAULT FALSE,
    CONSTRAINT uq_permission_id UNIQUE (app_id, fully_qualified_field_name,read_,create_,update_delete_)
);

CREATE TABLE auth.role_permission_id (
    id BIGINT PRIMARY KEY DEFAULT nextval('auth.seq_role_permission_id'),
    role_id BIGINT NOT NULL,
    permission_id BIGINT NOT NULL,
    CONSTRAINT uq_role_permission_id UNIQUE (role_id, permission_id)
);

